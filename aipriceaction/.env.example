# Database URL for sqlx CLI
POSTGRES_PASSWORD=<your-password>
DATABASE_URL=postgresql://aipriceaction:<your-password>@localhost:5432/aipriceaction

# VCI Workers (background sync from VCI API to PostgreSQL)
# Set to "false" or "0" to disable daily/hourly/minute workers
VCI_WORKERS=true

# VCI Dividend Worker (background re-download for dividend-detected tickers)
# Set to "false" or "0" to disable
VCI_DIVIDEND_WORKER=true

# Binance Workers (background sync from Binance API to PostgreSQL)
# Set to "true" or "1" to enable daily/hourly/minute crypto workers
BINANCE_WORKERS=true

# Yahoo Workers (background sync from Yahoo Finance API to PostgreSQL)
# Set to "true" or "1" to enable bootstrap/daily/hourly/minute workers
YAHOO_WORKERS=true

# SJC Workers (background sync from SJC gold price API)
# Set to "true" or "1" to enable bootstrap/daily SJC gold workers
SJC_WORKERS=true

# HTTP Proxies for VCI API (comma-separated, increases rate limit throughput)
# Each proxy adds a client with 60 req/min rate limit
# Example: HTTP_PROXIES=http://proxy1:8080,http://proxy2:8080
# HTTP_PROXIES=

# Allowed CORS origins (comma-separated). Default: https://aipriceaction.com
# Use "*" to allow all origins (development only)
# CORS_ORIGINS=https://aipriceaction.com

# Redis ZSET cache (edge cache for OHLCV data)
# Set to enable workers writing crawled data to Redis ZSET
REDIS_PASSWORD=<your-password>
# REDIS_URL=redis://default:<your-password>@localhost:6379/0

# Redis backfill worker (reads Redis ZSET counts, backfills missing data from PostgreSQL)
# Set to "true" or "1" to enable on a single instance
# REDIS_WORKERS=false

# Secret key for POST /tickers/refresh endpoint
# If not set, the refresh endpoint returns 403
REFRESH_SECRET=<your-secret>

# Bearer token for /sync KV-store endpoint (comma-separated for key rotation)
# If not set, the sync endpoint returns 403
SYNC_TOKEN=<your-sync-token>

# S3 Archive Worker (exports OHLCV data to S3 as daily CSV files)
# Set to "true" or "1" to enable
# S3_ARCHIVE_WORKER=false

# S3 Archive Worker loop interval in seconds (default: 3600 = 1 hour)
# S3_ARCHIVE_INTERVAL_SECS=3600

# S3 connection settings for archive worker
# Bucket is auto-created on first run if it doesn't exist.
# For local rustfs, credentials must match RUSTFS_ACCESS_KEY/RUSTFS_SECRET_KEY.
# S3_BUCKET=aipriceaction-archive
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# AWS_ACCESS_KEY_ID=rustfsadmin
# AWS_SECRET_ACCESS_KEY=rustfsadmin
